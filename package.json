{
  "name": "rugby-game-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Rugby game management platform",
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:backend": "tsx src/server.ts",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:backend && npm run build:client",
    "build:backend": "tsc -p tsconfig.json",
    "build:client": "cd client && npm run build",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.14",
    "@types/supertest": "^6.0.2",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}