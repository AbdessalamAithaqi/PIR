generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── User ────────────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  name      String
  role      String   // "TEACHER" or "STUDENT"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedGames      GameInstance[]
  teamMemberships TeamMember[]
}

// ─── GameInstance ─────────────────────────────────────────────────────────────
model GameInstance {
  id           String   @id @default(uuid())
  name         String
  joinCode     String   @unique
  status       String   @default("CREATED") // CREATED | ACTIVE | RESOLVING | FINISHED
  currentRound Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  teams   Team[]
  players Player[]
  matches Match[]
}

// ─── Team ────────────────────────────────────────────────────────────────────
model Team {
  id           String   @id @default(uuid())
  name         String
  budget       Float    @default(50000)
  fans         Int      @default(1000)
  pubScore     Int      @default(0)   // 0-10
  merchScore   Int      @default(0)   // 0-10
  leaguePoints Int      @default(0)
  wins         Int      @default(0)
  draws        Int      @default(0)
  losses       Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  gameId String
  game   GameInstance @relation(fields: [gameId], references: [id])

  members         TeamMember[]
  players         Player[]
  bids            Bid[]
  decisions       Decision[]
  matchesAsTeamA  Match[]      @relation("TeamAMatches")
  matchesAsTeamB  Match[]      @relation("TeamBMatches")
}

// ─── TeamMember ──────────────────────────────────────────────────────────────
model TeamMember {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
}

// ─── Player ──────────────────────────────────────────────────────────────────
model Player {
  id             String   @id @default(uuid())
  name           String
  position       String   // "Prop" | "Hooker" | "Lock" | etc.
  skillScore     Int
  basePrice      Int
  generatedRound Int
  status         String   @default("MARKET") // MARKET | OWNED
  createdAt      DateTime @default(now())

  gameId String
  game   GameInstance @relation(fields: [gameId], references: [id])

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  bids Bid[]
}

// ─── Bid ──────────────────────────────────────────────────────────────────────
model Bid {
  id          String   @id @default(uuid())
  roundNumber Int
  amount      Int
  status      String   @default("ACTIVE") // ACTIVE | WON | LOST
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([roundNumber, playerId, teamId])
}

// ─── Decision ─────────────────────────────────────────────────────────────────
model Decision {
  id               String   @id @default(uuid())
  roundNumber      Int
  pubInvestments   Int      @default(0)
  merchInvestments Int      @default(0)
  ready            Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([roundNumber, teamId])
}

// ─── Match ────────────────────────────────────────────────────────────────────
model Match {
  id           String   @id @default(uuid())
  roundNumber  Int
  teamAScore   Float?
  teamBScore   Float?
  winnerTeamId String?
  played       Boolean  @default(false)
  createdAt    DateTime @default(now())

  gameId String
  game   GameInstance @relation(fields: [gameId], references: [id])

  teamAId String
  teamA   Team   @relation("TeamAMatches", fields: [teamAId], references: [id])

  teamBId String
  teamB   Team   @relation("TeamBMatches", fields: [teamBId], references: [id])
}